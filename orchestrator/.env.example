# Flow Telephony Orchestrator Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# Backend Service URLs
# =============================================================================

# Voxtral ASR Realtime WebSocket
ASR_WS_URL=ws://127.0.0.1:8001/v1/realtime

# Nemotron LLM HTTP Endpoint
LLM_URL=http://127.0.0.1:8000/v1/chat/completions

# MOSS-TTS HTTP Endpoint
TTS_URL=http://127.0.0.1:8002/v1/audio/speech

# =============================================================================
# VAD Configuration
# =============================================================================

# Path to Silero VAD ONNX model
VAD_MODEL_PATH=./models/silero_vad.onnx

# =============================================================================
# TTS / Voice Configuration
# =============================================================================

# Option 1: Voice name (default, "professional", etc.)
# TTS_VOICE=default

# Option 2: Zero-shot voice cloning from audio file
# Place a reference WAV file (8-16kHz, mono, 5-10 seconds) and set path:
# TTS_VOICE_FILE=/path/to/reference_speaker.wav

# Option 3: Base64-encoded reference audio (advanced)
# TTS_VOICE=data:audio/wav;base64,UklGRiQAAABXQVZFZm10IBAAAAABAAEA...

# =============================================================================
# LLM Configuration (Reasoning Disabled for Low Latency)
# =============================================================================

# The system prompt is pre-configured in code with:
# - Reasoning/thinking disabled
# - Backchanneling enabled ("um", "ahh", "hmm", "...")
# - Natural conversational style
#
# Only override if you need specific behavior:
# LLM_SYSTEM_PROMPT="Your custom prompt here"

# =============================================================================
# Performance Tuning
# =============================================================================

# Tokio worker threads (default: 16)
# TOKIO_WORKER_THREADS=16

# Audio buffer size (default: 1000)
# AUDIO_BUFFER_SIZE=1000

# VAD silence timeout in ms (default: 600)
# VAD_SILENCE_TIMEOUT_MS=600

# =============================================================================
# Logging
# =============================================================================

# RUST_LOG=info
# RUST_LOG=debug  # For verbose debugging
