# Flow Telephony Orchestrator Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# Backend Service URLs
# =============================================================================

# Voxtral ASR Realtime WebSocket
ASR_WS_URL=ws://127.0.0.1:8001/v1/realtime

# Nemotron LLM HTTP Endpoint
LLM_URL=http://127.0.0.1:8000/v1/chat/completions

# MOSS-TTS HTTP Endpoint
TTS_URL=http://127.0.0.1:8002/v1/audio/speech

# =============================================================================
# VAD Configuration
# =============================================================================

# Path to Silero VAD ONNX model
VAD_MODEL_PATH=./models/silero_vad.onnx

# =============================================================================
# TTS Configuration
# =============================================================================

# Voice to use (or reference audio base64 for zero-shot cloning)
# Leave empty for default voice
TTS_VOICE=default

# Alternative: Base64-encoded reference audio for voice cloning
# TTS_VOICE=data:audio/wav;base64,UklGRiQAAABXQVZFZm10IBAAAAABAAEA...

# =============================================================================
# LLM Configuration
# =============================================================================

# System prompt for the voice assistant
LLM_SYSTEM_PROMPT="You are a helpful voice assistant for telephone conversations. Keep responses concise and natural."

# Alternative: Customer service persona
# LLM_SYSTEM_PROMPT="You are a professional customer service representative. Be polite, helpful, and efficient."

# =============================================================================
# Performance Tuning (Optional)
# =============================================================================

# Tokio worker threads (default: 16)
# TOKIO_WORKER_THREADS=16

# Audio buffer size (default: 1000)
# AUDIO_BUFFER_SIZE=1000

# VAD silence timeout in ms (default: 600)
# VAD_SILENCE_TIMEOUT_MS=600

# =============================================================================
# LiveKit Configuration (Future)
# =============================================================================

# LiveKit server URL
# LIVEKIT_URL=wss://livekit.yourdomain.com

# API key and secret
# LIVEKIT_API_KEY=your_key
# LIVEKIT_API_SECRET=your_secret

# Room name prefix
# LIVEKIT_ROOM_PREFIX=call_
